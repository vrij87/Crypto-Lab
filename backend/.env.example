# API Configuration
# SQLite / PostgreSQL Connection URL
DATABASE_URL=sqlite:///./cryptolab.db

# Supabase JWT Secret (found in Supabase Dashboard -> Project Settings -> API)
# Used to verify user JWT signatures for progress synchronization.
# If left blank, the backend will decode JWT claims without signature verification (Mock Sandbox Mode).
SUPABASE_JWT_SECRET=

# Password Hash Security Pepper
PASSWORD_PEPPER=CryptoLabSuperSecurePepper2026!
